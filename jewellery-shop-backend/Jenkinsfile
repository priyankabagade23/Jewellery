pipeline {
    agent any
    
    triggers {
        pollSCM('H/1 * * * *') // Poll every 1 minute as fallback
        // GitHub webhook trigger will be configured in Jenkins UI
    }
    
    environment {
        DOCKER_IMAGE = 'jewellery-shop-backend'
        DOCKER_TAG = 'latest'
        AWS_REGION = 'us-east-1'
        ECR_REPOSITORY = 'jewellery-shop-backend'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scmGit(
                    branches: [[name: '*/main']],
                    extensions: [],
                    userRemoteConfigs: [[url: 'https://github.com/priyankabagade23/Jewellery.git']]
                )
            }
        }
        
        stage('Build Maven Project') {
            steps {
                dir('jewellery-shop-backend') {
                    sh 'chmod +x mvnw'
                    timeout(time: 10, unit: 'MINUTES') {
                        sh 'export MAVEN_OPTS="-Xmx1024m" && ./mvnw package -DskipTests'
                    }
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                dir('jewellery-shop-backend') {
                    script {
                        docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}", '.')
                    }
                }
            }
        }
        
        stage('Test') {
            steps {
                dir('jewellery-shop-backend') {
                    timeout(time: 10, unit: 'MINUTES') {
                        sh 'export MAVEN_OPTS="-Xmx1024m" && ./mvnw test'
                    }
                }
            }
            post {
                always {
                    dir('jewellery-shop-backend') {
                        junit 'target/surefire-reports/*.xml'
                    }
                }
            }
        }
        
        stage('Deploy to Docker Container') {
            steps {
                script {
                    // Stop and remove existing container
                    sh 'docker stop jewellery-shop-container || true'
                    sh 'docker rm jewellery-shop-container || true'
                    
                    // Run new container
                    sh """
                        docker run -d \
                        --name jewellery-shop-container \
                        -p 8081:8080 \
                        ${DOCKER_IMAGE}:${DOCKER_TAG}
                    """
                }
            }
        }
    }
    
    post {
        success {
            echo 'Deployment successful!'
            echo 'Application is running on http://localhost:8081'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}
